{
  "rules": {
    
    // =====================================================================
    // 1. NODE PENGGUNA & HAK AKSES (RBAC - ROLE BASED ACCESS CONTROL)
    // =====================================================================
    "users": {
      "$uid": {
        // READ: User bisa membaca profilnya sendiri, ATAU Super Admin & Admin bisa membaca semuanya
        ".read": "auth != null && (auth.uid === $uid || root.child('users/' + auth.uid + '/role').val() === 'super_admin' || root.child('users/' + auth.uid + '/role').val() === 'admin')",
        
        // WRITE: HANYA Super Admin yang diizinkan mendaftar, mengedit, atau menghapus pengguna
        ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() === 'super_admin'"
      }
    },

    // =====================================================================
    // 2. NODE DATA MARKET & TERMINAL BOT (DATA ISOLATION)
    // =====================================================================
    "account_data": {
      "$account_id": {
        // READ: Bisa dibaca jika user adalah Super Admin/Admin, ATAU jika $account_id ini bernilai 'true' di node 'owned_accounts' milik Investor tersebut
        ".read": "auth != null && (root.child('users/' + auth.uid + '/role').val() === 'super_admin' || root.child('users/' + auth.uid + '/role').val() === 'admin' || root.child('users/' + auth.uid + '/owned_accounts/' + $account_id).val() === true)",
        
        // WRITE: Data ini biasanya ditulis oleh Bot Python (menggunakan Admin SDK yang menembus rules). 
        // Jika dari Web, hanya Super Admin dan Admin yang boleh menulis.
        ".write": "auth != null && (root.child('users/' + auth.uid + '/role').val() === 'super_admin' || root.child('users/' + auth.uid + '/role').val() === 'admin')"
      }
    },

    // =====================================================================
    // 3. NODE LISENSI & ALERTS (MENGGUNAKAN ATURAN LAMA ANDA)
    // =====================================================================
    "licenses": {
      "$account": {
        ".read": "auth != null || true",
        ".write": "auth != null",
        "license_key": { ".validate": "newData.isString() && newData.val().matches(/^KRX-[A-Z0-9]{4}-[A-Z0-9]{4}-[A-Z0-9]{4}$/)" },
        "membership_type": { ".validate": "newData.isString() && (newData.val() === 'TRIAL' || newData.val() === 'MONTHLY' || newData.val() === '3MONTHS')" },
        "is_ib": { ".validate": "newData.isBoolean()" },
        "price_paid": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "broker_server": { ".validate": "newData.isString() && newData.val().length > 0" },
        "generated_at": { ".validate": "newData.isNumber()" },
        "expiry_date": { ".validate": "newData.isNumber()" },
        "status": { ".validate": "newData.isString() && (newData.val() === 'ACTIVE' || newData.val() === 'EXPIRED' || newData.val() === 'SUSPENDED')" },
        "vps_rental": { ".validate": "newData.isBoolean()" },
        "vps_deposit_paid": { ".validate": "newData.isBoolean()" },
        "vps_remaining": { ".validate": "newData.isNumber()" },
        "last_heartbeat": { ".validate": "newData.isNumber()" },
        "daily_summary": {
          "$date": {
            ".read": "auth != null || true",
            ".write": "auth != null || true",
            "lot_total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "profit_loss": { ".validate": "newData.isNumber()" },
            "start_time": { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{2}:[0-9]{2}$/)" },
            "last_update": { ".validate": "newData.isString()" }
          }
        }
      }
    },
    "trial_used_accounts": {
      "$account": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.isBoolean() && newData.val() === true"
      }
    },
    "alerts": {
      "$account": {
        ".read": "auth != null || true",
        ".write": "auth != null || true",
        "message": { ".validate": "newData.isString()" },
        "timestamp": { ".validate": "newData.isNumber()" },
        "type": { ".validate": "newData.isString()" }
      }
    }
  }
}